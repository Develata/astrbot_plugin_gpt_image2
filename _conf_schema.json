{
  "api": {
    "type": "object",
    "description": "Images API",
    "items": {
      "base_url": {
        "type": "string",
        "description": "API Base URL",
        "default": "https://api.openai.com/v1"
      },
      "api_key": {
        "type": "string",
        "description": "API Key",
        "default": "",
        "token": true
      },
      "model": {
        "type": "string",
        "description": "模型名",
        "default": "gpt-image-2"
      },
      "timeout_seconds": {
        "type": "int",
        "description": "请求超时秒数",
        "default": 900
      },
      "fallback_enabled": {
        "type": "bool",
        "description": "启用备用 API",
        "default": false
      },
      "fallback_endpoints": {
        "type": "template_list",
        "description": "备用 API 列表",
        "default": [],
        "templates": {
          "fallback_endpoint": {
            "name": "Fallback API",
            "display_item": "base_url",
            "hide_hint_in_list": true,
            "items": {
              "base_url": {
                "type": "string",
                "description": "Fallback API Base URL",
                "default": ""
              },
              "api_key": {
                "type": "string",
                "description": "Fallback API Key",
                "default": "",
                "token": true
              },
              "model": {
                "type": "string",
                "description": "Fallback Model",
                "default": "gpt-image-2"
              }
            }
          }
        }
      }
    }
  },
  "defaults": {
    "type": "object",
    "description": "默认图像参数",
    "items": {
      "size": {
        "type": "string",
        "description": "默认尺寸",
        "default": "1536x1024",
        "options": [
          "1024x1024",
          "1536x1024",
          "1024x1536"
        ]
      },
      "quality": {
        "type": "string",
        "description": "默认质量",
        "default": "medium",
        "options": [
          "low",
          "medium",
          "high",
          "auto"
        ]
      },
      "output_format": {
        "type": "string",
        "description": "输出格式",
        "default": "png",
        "options": [
          "png",
          "jpeg",
          "webp"
        ]
      },
      "background": {
        "type": "string",
        "description": "背景模式",
        "default": "auto",
        "options": [
          "auto",
          "transparent",
          "opaque"
        ]
      }
    }
  },
  "runtime": {
    "type": "object",
    "description": "后台队列",
    "items": {
      "global_max_concurrent": {
        "type": "int",
        "description": "全局上游并发",
        "default": 1
      },
      "queue_max_size": {
        "type": "int",
        "description": "最大未完成任务数",
        "default": 5
      },
      "job_ttl_hours": {
        "type": "int",
        "description": "任务保存小时数",
        "default": 24
      },
      "send_start_message": {
        "type": "bool",
        "description": "发送开始提示",
        "default": true
      },
      "send_finish_message": {
        "type": "bool",
        "description": "发送完成 caption",
        "default": true
      },
      "per_user_queue_max_size": {
        "type": "int",
        "description": "单用户未完成任务上限",
        "default": 5
      },
      "cleanup_interval_minutes": {
        "type": "int",
        "description": "缓存清理间隔分钟",
        "default": 360,
        "min": 0,
        "max": 10080
      },
      "max_cache_mb": {
        "type": "int",
        "description": "缓存体积上限 MB",
        "default": 1024,
        "min": 0,
        "max": 1048576
      },
      "quiet_mode": {
        "type": "bool",
        "description": "静默生图模式",
        "default": false
      }
    }
  },
  "llm_tool": {
    "type": "object",
    "description": "LLM Tool",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用 LLM Tool",
        "default": true
      },
      "default_size": {
        "type": "string",
        "description": "默认尺寸",
        "default": "1536x1024",
        "options": [
          "1024x1024",
          "1536x1024",
          "1024x1536"
        ]
      },
      "default_quality": {
        "type": "string",
        "description": "默认质量",
        "default": "medium",
        "options": [
          "low",
          "medium",
          "high",
          "auto"
        ]
      },
      "require_explicit_image_intent": {
        "type": "bool",
        "description": "要求明确生图意图",
        "default": true
      }
    }
  },
  "edit": {
    "type": "object",
    "description": "改图设置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用改图",
        "default": true
      },
      "max_reference_images": {
        "type": "int",
        "description": "最多参考图数量",
        "default": 4
      },
      "max_reference_image_mb": {
        "type": "int",
        "description": "单张参考图最大 MB",
        "default": 20
      },
      "materialize_timeout_seconds": {
        "type": "int",
        "description": "参考图提取超时秒数",
        "default": 10,
        "min": 1,
        "max": 60
      }
    }
  },
  "prompt": {
    "type": "object",
    "description": "Prompt 设置",
    "items": {
      "prefix": {
        "type": "text",
        "description": "Prompt 前缀",
        "default": ""
      }
    }
  },
  "access": {
    "type": "object",
    "description": "使用限制",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用使用限制",
        "default": false
      },
      "user_blacklist": {
        "type": "text",
        "description": "用户 ID 黑名单",
        "default": ""
      },
      "user_whitelist": {
        "type": "text",
        "description": "用户 ID 白名单",
        "default": ""
      },
      "group_whitelist": {
        "type": "text",
        "description": "群组 ID 白名单",
        "default": ""
      },
      "non_whitelist_daily_limit": {
        "type": "int",
        "description": "非白名单每日额度",
        "default": 0,
        "min": 0,
        "max": 10000
      }
    }
  }
}
